# Copy to `.env` (the compose env_file) and fill in your values.
#   cp .env.docker.example .env
# This file is git/docker-ignored where named `.env` — never commit real secrets.

# ── Execution mode ────────────────────────────────────────────────────────────
# Keep True: run LLM-generated factor/backtest code locally inside the container.
USE_LOCAL=True

# ── Build options (read by docker compose at build time) ──────────────────────
# Debian apt mirror used during `docker compose build`. On networks where
# deb.debian.org is slow or blocked (e.g. behind a proxy that 503s HTTP), set a
# closer mirror, e.g. mirrors.aliyun.com or mirrors.tuna.tsinghua.edu.cn.
# APT_MIRROR=mirrors.aliyun.com

# ── LLM API (required for mining) ─────────────────────────────────────────────
OPENAI_BASE_URL=<your_base_url>
OPENAI_API_KEY=<your_api_key>
CHAT_MODEL=<your_chat_model>            # e.g. "deepseek-v3"
REASONING_MODEL=<your_reasoning_model> # e.g. "deepseek-reasoner"
EMBEDDING_MODEL=text-embedding-3-small

CHAT_MAX_TOKENS=4000
CHAT_TEMPERATURE=0.7
MAX_RETRY=5
RETRY_WAIT_SECONDS=5
FACTOR_MINING_TIMEOUT=10800            # max factor mining run time (seconds)

# LLM prompt/response logs under log/*/llm_messages/ (viewable in the portal UI)
LOG_LLM_CHAT_TO_FILE=True
LOG_LLM_CHAT_TO_CONSOLE=False

# ── Portal bind (compose already sets these; here for reference) ──────────────
ALPHAPILOT_PORTAL_HOST=0.0.0.0
ALPHAPILOT_PORTAL_PORT=19901

# ── Market data ───────────────────────────────────────────────────────────────
# Downloaded at runtime into ./docker-data/qlib-data (~2.4 GB) on the first data job.
# Tushare needs a token; baostock does not. Leave blank to use baostock only.
# TUSHARE_TOKEN=<your_tushare_pro_token>

# ── Notify channels (only for the `notify` service / bot commands) ────────────
# Credentials persist in ~/.alphapilot/credentials/notify.json (the
# ./docker-data/app-config mount) once set via the portal UI. Or override here:
# ALPHAPILOT_NOTIFY_TELEGRAM_BOT_TOKEN=<telegram_bot_token>
# ALPHAPILOT_NOTIFY_TELEGRAM_CHAT_ID=<telegram_chat_id>
# ALPHAPILOT_NOTIFY_FEISHU_WEBHOOK=<feishu_webhook_url>
# ALPHAPILOT_NOTIFY_FEISHU_APP_ID=<feishu_app_id>
# ALPHAPILOT_NOTIFY_FEISHU_APP_SECRET=<feishu_app_secret>
# ALPHAPILOT_NOTIFY_FEISHU_VERIFICATION_TOKEN=<feishu_verification_token>
