# Keep the build context small and never bake secrets / runtime state into the image.

# Secrets & local env (inject at runtime via compose env_file instead)
.env
.env.*
!.env.docker.example

# Runtime state / large caches & data (these are volumes, ~1.9GB locally)
git_ignore_folder/
pickle_cache/
log/
*.h5
**/mlruns/

# VCS (excluded -> set SETUPTOOLS_SCM_PRETEND_VERSION at build time)
.git/
**/.git/
.gitignore

# Vendored broker SDK originals: their headers/libs are copied into the
# vnpy_xtp / vnpy_emt packages, so the raw SDK folders never enter the image.
XTP_API_20250806_2.2.50.8/
emt_api/
# vn.py repo extras not needed to pip-install it
vnpy/docs/
vnpy/examples/
vnpy/tests/

# Frontend: node_modules + any local dist are rebuilt in the web-builder stage
alphapilot/modules/portal/web/node_modules/
alphapilot/modules/portal/web/dist/
**/node_modules/

# Python build / cache artifacts
**/__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/
.eggs/

# Tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.idea/
.vscode/
.DS_Store

# Tests are not needed in the runtime image
tests/

# Docker artifacts themselves
Dockerfile
docker-compose.yml
.dockerignore
