"""
This file is a template for the .env file.

Please copy this file to .env and fill in the values.

For more information about configuration options, please refer to the documentation

"""

# Global configs:
USE_AZURE=False
CHAT_USE_AZURE_TOKEN_PROVIDER=False
EMBEDDING_USE_AZURE_TOKEN_PROVIDER=False
MAX_RETRY=5
RETRY_WAIT_SECONDS=5
FACTOR_MINING_TIMEOUT=10800 # 最大运行时间
USE_LOCAL=True

# LLM API Setting:
OPENAI_BASE_URL=<your_base_url>
OPENAI_API_KEY=<your_api_key>
CHAT_MODEL=<your_chat_model> # e.g., "deepseek-v3"
REASONING_MODEL=<your_reasoning_model> # e.g. "deepseek-reasoner"
EMBEDDING_MODEL=text-embedding-3-small # RAG

CHAT_MAX_TOKENS=4000
CHAT_TEMPERATURE=0.7

# LLM logs: prompts/responses under log/*/llm_messages/ (viewable in alphapilot ui)
LOG_LLM_CHAT_TO_FILE=True
LOG_LLM_CHAT_TO_CONSOLE=False
# Legacy (optional): LOG_LLM_CHAT_CONTENT=True enables both file and console

# Data paths (optional overrides; defaults resolve under ~/.qlib/qlib_data/cn_data/)
# Baostock CSV:   cn_data/baostock/raw_data_{no,forward,back}_adjust
# Baostock Qlib:  cn_data/baostock/qlib
# Tushare CSV:    cn_data/tushare/raw_data_{no,forward,back}_adjust
# Tushare Qlib:   cn_data/tushare/qlib
# ALPHAPILOT_QLIB_DATA_DIR=~/.qlib/qlib_data/cn_data/baostock/qlib
# ALPHAPILOT_RAW_DATA_DIR=~/.qlib/qlib_data/cn_data/baostock/raw_data_back_adjust
# ALPHAPILOT_ADJUST_FACTOR_DIR=~/.qlib/qlib_data/cn_data/baostock/adjust_factors
# TUSHARE_TOKEN=<your_tushare_pro_token>

# Qlib factor backtest / mine / strategy_backtest (optional; shared QLIB_FACTOR_ prefix)
# Template folder copied into each RD-Agent_workspace before qrun (.py/.yaml/.md only)
# QLIB_FACTOR_QLIB_TEMPLATE_DIR=important_data/factor_qlib_templates
# ALPHAPILOT_STRATEGY_PARAM_DIR=important_data/strategy_zoo
# ALPHAPILOT_FACTOR_ZOO_DIR=important_data/factor_zoo
# ALPHAPILOT_IMPORTANT_DATA_DIR=important_data
# QLIB_FACTOR_QLIB_CONFIG_NAME=conf_cn_combined_kdd_ver.yaml

# Pickle cache (mine vs backtest use separate roots by default)
# ALPHAPILOT_PICKLE_CACHE_ENABLED=true
# ALPHAPILOT_PICKLE_CACHE_DIR_MINE=pickle_cache/mine
# ALPHAPILOT_PICKLE_CACHE_DIR_BACKTEST=pickle_cache/backtest
# Legacy single root when scope is unset (also: PICKLE_CACHE_FOLDER_PATH_STR)
# ALPHAPILOT_PICKLE_CACHE_DIR=pickle_cache

# Factor factor.py subprocess (default: current interpreter sys.executable)
# FACTOR_CoSTEER_PYTHON_BIN=/path/to/conda/envs/alphapilot/bin/python